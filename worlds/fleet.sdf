<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="fleet">

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
          <surface>
            <friction><ode><mu>100</mu><mu2>50</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- tb1: orange, starts at (0, 1) — will be driven to demonstrate movement -->
    <model name="tb1">
      <pose>0 1.0 0 0 0 0</pose>

      <link name="base_link">
        <pose>0 0 0.010 0 0 0</pose>
        <inertial>
          <mass>8.2573504e-01</mass>
          <inertia>
            <ixx>2.2124416e-03</ixx><ixy>-1.2294101e-05</ixy><ixz>3.4938785e-05</ixz>
            <iyy>2.1193702e-03</iyy><iyz>-5.0120904e-06</iyz>
            <izz>2.0064271e-03</izz>
          </inertia>
        </inertial>
        <visual name="visual_body">
          <pose>-0.032 0 0.070 0 0 0</pose>
          <geometry><box><size>0.140 0.140 0.143</size></box></geometry>
          <material>
            <ambient>0.9 0.5 0.0 1</ambient>
            <diffuse>0.9 0.5 0.0 1</diffuse>
          </material>
        </visual>
        <collision name="collision_body">
          <pose>-0.032 0 0.070 0 0 0</pose>
          <geometry><box><size>0.140 0.140 0.143</size></box></geometry>
        </collision>
      </link>

      <link name="wheel_left_link">
        <pose>0.0 0.080 0.033 -1.5707963 0 0</pose>
        <inertial>
          <mass>2.8498940e-02</mass>
          <inertia>
            <ixx>1.1175580e-05</ixx><ixy>-4.2369783e-11</ixy><ixz>-5.9381719e-09</ixz>
            <iyy>1.1192413e-05</iyy><iyz>-1.4400107e-11</iyz>
            <izz>2.0712558e-05</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        </collision>
      </link>

      <link name="wheel_right_link">
        <pose>0.0 -0.080 0.033 -1.5707963 0 0</pose>
        <inertial>
          <mass>2.8498940e-02</mass>
          <inertia>
            <ixx>1.1175580e-05</ixx><ixy>-4.2369783e-11</ixy><ixz>-5.9381719e-09</ixz>
            <iyy>1.1192413e-05</iyy><iyz>-1.4400107e-11</iyz>
            <izz>2.0712558e-05</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        </collision>
      </link>

      <link name="caster_back_link">
        <pose>-0.081 0 0.033 0 0 0</pose>
        <inertial>
          <mass>0.005</mass>
          <inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia>
        </inertial>
        <visual name="visual">
          <geometry><sphere><radius>0.033</radius></sphere></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
        </visual>
        <collision name="collision">
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
          <geometry><sphere><radius>0.033</radius></sphere></geometry>
        </collision>
      </link>

      <joint name="wheel_left_joint" type="revolute">
        <parent>base_link</parent>
        <child>wheel_left_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
          <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
        </axis>
      </joint>

      <joint name="wheel_right_joint" type="revolute">
        <parent>base_link</parent>
        <child>wheel_right_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
          <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
        </axis>
      </joint>

      <joint name="caster_back_joint" type="ball">
        <parent>base_link</parent>
        <child>caster_back_link</child>
      </joint>

      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>wheel_left_joint</left_joint>
        <right_joint>wheel_right_joint</right_joint>
        <wheel_separation>0.160</wheel_separation>
        <wheel_radius>0.033</wheel_radius>
        <odom_publish_frequency>10</odom_publish_frequency>
        <topic>/tb1/cmd_vel</topic>
        <odom_topic>/tb1/odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <frame_id>tb1/odom</frame_id>
        <child_frame_id>tb1/base_footprint</child_frame_id>
      </plugin>

      <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        <topic>/tb1/joint_states</topic>
      </plugin>
    </model>

    <!-- tb2: blue, starts at (0, -1) — no cmd_vel → STUCK alert fires -->
    <model name="tb2">
      <pose>0 -1.0 0 0 0 0</pose>

      <link name="base_link">
        <pose>0 0 0.010 0 0 0</pose>
        <inertial>
          <mass>8.2573504e-01</mass>
          <inertia>
            <ixx>2.2124416e-03</ixx><ixy>-1.2294101e-05</ixy><ixz>3.4938785e-05</ixz>
            <iyy>2.1193702e-03</iyy><iyz>-5.0120904e-06</iyz>
            <izz>2.0064271e-03</izz>
          </inertia>
        </inertial>
        <visual name="visual_body">
          <pose>-0.032 0 0.070 0 0 0</pose>
          <geometry><box><size>0.140 0.140 0.143</size></box></geometry>
          <material>
            <ambient>0.0 0.4 0.9 1</ambient>
            <diffuse>0.0 0.4 0.9 1</diffuse>
          </material>
        </visual>
        <collision name="collision_body">
          <pose>-0.032 0 0.070 0 0 0</pose>
          <geometry><box><size>0.140 0.140 0.143</size></box></geometry>
        </collision>
      </link>

      <link name="wheel_left_link">
        <pose>0.0 0.080 0.033 -1.5707963 0 0</pose>
        <inertial>
          <mass>2.8498940e-02</mass>
          <inertia>
            <ixx>1.1175580e-05</ixx><ixy>-4.2369783e-11</ixy><ixz>-5.9381719e-09</ixz>
            <iyy>1.1192413e-05</iyy><iyz>-1.4400107e-11</iyz>
            <izz>2.0712558e-05</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        </collision>
      </link>

      <link name="wheel_right_link">
        <pose>0.0 -0.080 0.033 -1.5707963 0 0</pose>
        <inertial>
          <mass>2.8498940e-02</mass>
          <inertia>
            <ixx>1.1175580e-05</ixx><ixy>-4.2369783e-11</ixy><ixz>-5.9381719e-09</ixz>
            <iyy>1.1192413e-05</iyy><iyz>-1.4400107e-11</iyz>
            <izz>2.0712558e-05</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        </collision>
      </link>

      <link name="caster_back_link">
        <pose>-0.081 0 0.033 0 0 0</pose>
        <inertial>
          <mass>0.005</mass>
          <inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia>
        </inertial>
        <visual name="visual">
          <geometry><sphere><radius>0.033</radius></sphere></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
        </visual>
        <collision name="collision">
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
          <geometry><sphere><radius>0.033</radius></sphere></geometry>
        </collision>
      </link>

      <joint name="wheel_left_joint" type="revolute">
        <parent>base_link</parent>
        <child>wheel_left_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
          <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
        </axis>
      </joint>

      <joint name="wheel_right_joint" type="revolute">
        <parent>base_link</parent>
        <child>wheel_right_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
          <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
        </axis>
      </joint>

      <joint name="caster_back_joint" type="ball">
        <parent>base_link</parent>
        <child>caster_back_link</child>
      </joint>

      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>wheel_left_joint</left_joint>
        <right_joint>wheel_right_joint</right_joint>
        <wheel_separation>0.160</wheel_separation>
        <wheel_radius>0.033</wheel_radius>
        <odom_publish_frequency>10</odom_publish_frequency>
        <topic>/tb2/cmd_vel</topic>
        <odom_topic>/tb2/odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <frame_id>tb2/odom</frame_id>
        <child_frame_id>tb2/base_footprint</child_frame_id>
      </plugin>

      <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        <topic>/tb2/joint_states</topic>
      </plugin>
    </model>

  </world>
</sdf>
